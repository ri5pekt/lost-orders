# ── Google OAuth (for user login) ────────────────────────────────────────────
# Go to console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID of type "Web application"
# Add your VPS URL as an Authorised redirect URI:
#   https://yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must match the redirect URI registered in Google Cloud Console exactly
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback

# ── App security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# Only Google accounts from this domain can log in
ALLOWED_DOMAIN=particleformen.com

# ── Gmail / PDF settings ──────────────────────────────────────────────────────
GMAIL_EMAIL=customerinvoices@particleformen.com

# Only search emails after this date (YYYY/MM/DD)
GMAIL_AFTER_DATE=2024/01/01

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=production
